#!/bin/bash
#==============================================================================
# Claudian Auto-Expand Partition
# Expands the root partition to fill available disk space on first boot
#==============================================================================

EXPANSION_FLAG="/root/.claudian-partition-expanded"

# Check if already expanded
if [ -f "$EXPANSION_FLAG" ]; then
    exit 0
fi

# Only run if we're on a real disk (not in a VM with existing full partition)
ROOT_DEV=$(findmnt -n -o SOURCE /)
if [ -z "$ROOT_DEV" ]; then
    echo "Could not determine root device"
    exit 1
fi

# Get the disk device (strip partition number)
DISK_DEV=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//')
PART_NUM=$(echo "$ROOT_DEV" | grep -o '[0-9]*$')

echo "Expanding partition on $ROOT_DEV (disk: $DISK_DEV, partition: $PART_NUM)..."

# Use growpart to expand the partition
if command -v growpart >/dev/null 2>&1; then
    growpart "$DISK_DEV" "$PART_NUM" 2>/dev/null || echo "Partition already at maximum size"
else
    echo "growpart not available, skipping partition expansion"
fi

# Resize the filesystem
if [ -n "$ROOT_DEV" ]; then
    resize2fs "$ROOT_DEV" 2>/dev/null || echo "Filesystem resize skipped or failed"
fi

# Mark as complete
touch "$EXPANSION_FLAG"
echo "Partition expansion complete!"
