#!/bin/bash
#==============================================================================
# Claudian Onboarding - First Boot Setup
# Handles partition setup and authentication on first boot
#==============================================================================

set -e

ONBOARDING_COMPLETE_FLAG="$HOME/.claudian-onboarding-complete"
ENV_FILE="/etc/environment"

# Check if onboarding is needed
if [ -f "$ONBOARDING_COMPLETE_FLAG" ]; then
    # Already completed
    exit 0
fi

# Check if API key is already set
if grep -q "^ANTHROPIC_API_KEY=" "$ENV_FILE" 2>/dev/null; then
    # API key already configured, mark as complete
    touch "$ONBOARDING_COMPLETE_FLAG"
    exit 0
fi

# Clear screen and show welcome
clear
cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║                                                                ║
║                   Welcome to Claudian OS                       ║
║                                                                ║
║          Where Claude Code operates your machine               ║
║                                                                ║
╚════════════════════════════════════════════════════════════════╝

EOF

# --- Step 1: Network Configuration ---
echo "First, let's set up network connectivity."
echo ""

# Check if already connected
if ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
    echo "✓ Network connection detected"
    echo ""
    sleep 1
else
    echo "No network connection detected."
    echo ""
    echo "Choose your network setup:"
    echo ""
    echo "  1) Connect to WiFi"
    echo "     Use NetworkManager to connect to a wireless network"
    echo ""
    echo "  2) Use Ethernet / Skip"
    echo "     Continue without configuring WiFi (ethernet should work automatically)"
    echo ""

    while true; do
        read -p "Enter choice [1 or 2]: " network_choice
        case $network_choice in
            1)
                echo ""
                echo "Scanning for WiFi networks..."
                echo ""

                # Scan for networks
                sudo nmcli device wifi rescan 2>/dev/null || true
                sleep 2

                # List available networks
                echo "Available networks:"
                sudo nmcli device wifi list
                echo ""

                # Ask for SSID
                read -p "Enter WiFi network name (SSID): " wifi_ssid

                if [ -z "$wifi_ssid" ]; then
                    echo "No SSID provided, skipping WiFi setup"
                    sleep 1
                    break
                fi

                # Ask for password
                read -sp "Enter WiFi password (leave empty for open network): " wifi_password
                echo ""

                # Connect
                echo "Connecting to '$wifi_ssid'..."
                if [ -z "$wifi_password" ]; then
                    # Open network
                    if sudo nmcli device wifi connect "$wifi_ssid"; then
                        echo ""
                        echo "✓ Connected to $wifi_ssid"
                        echo ""
                        sleep 2
                        break
                    else
                        echo ""
                        echo "✗ Connection failed"
                        echo ""
                        read -p "Press Enter to try again or Ctrl+C to abort..."
                    fi
                else
                    # Secured network
                    if sudo nmcli device wifi connect "$wifi_ssid" password "$wifi_password"; then
                        echo ""
                        echo "✓ Connected to $wifi_ssid"
                        echo ""
                        sleep 2
                        break
                    else
                        echo ""
                        echo "✗ Connection failed. Check your password and try again."
                        echo ""
                        read -p "Press Enter to try again or Ctrl+C to abort..."
                    fi
                fi
                ;;
            2)
                echo ""
                echo "Skipping WiFi configuration"
                echo ""
                sleep 1
                break
                ;;
            *)
                echo "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
fi

# --- Step 2: Partition Size Setup ---
# Must happen BEFORE package installation so there's enough disk space
clear
cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║                   Storage Configuration                        ║
╚════════════════════════════════════════════════════════════════╝

EOF

echo "Let's configure your storage partition."
echo "This must happen before installing extra packages."
echo ""

# Get current partition info
ROOT_DEV=$(findmnt -n -o SOURCE /)
if [ -n "$ROOT_DEV" ]; then
    CURRENT_SIZE=$(df -h / | tail -1 | awk '{print $2}')
    DISK_DEV=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//')
    if [ -b "$DISK_DEV" ]; then
        DISK_SIZE=$(lsblk -b -d -n -o SIZE "$DISK_DEV" 2>/dev/null)
        DISK_SIZE_GB=$((DISK_SIZE / 1024 / 1024 / 1024))
        echo "Current partition: $CURRENT_SIZE"
        echo "Available on disk: ${DISK_SIZE_GB}GB"
        echo ""
    fi
fi

echo "How would you like to configure storage?"
echo ""
echo "  1) Auto-expand to fill entire drive (recommended)"
echo "     Partition will grow to use all available space"
echo ""
echo "  2) Set a specific size"
echo "     Choose a custom partition size (e.g., 20GB, 50GB)"
echo ""
echo "  3) Keep current size"
echo "     Don't expand the partition"
echo ""

while true; do
    read -p "Enter choice [1, 2, or 3]: " partition_choice
    case $partition_choice in
        1)
            echo ""
            echo "Expanding partition to fill drive..."
            sudo /usr/local/bin/claudian-expand-partition auto 2>&1 | grep -v "^$" || true
            echo ""
            sleep 2
            break
            ;;
        2)
            echo ""
            echo "Enter desired partition size (e.g., 20G, 50G, 100G):"
            read -p "Size: " custom_size

            # Basic validation
            if [[ "$custom_size" =~ ^[0-9]+[GgMm]$ ]]; then
                echo ""
                echo "Setting partition to $custom_size..."
                sudo /usr/local/bin/claudian-expand-partition "$custom_size" 2>&1 | grep -v "^$" || true
                echo ""
                sleep 2
                break
            else
                echo ""
                echo "✗ Invalid format. Use format like: 20G, 50G, 100G"
                echo ""
            fi
            ;;
        3)
            echo ""
            echo "Keeping current partition size"
            echo ""
            sleep 1
            break
            ;;
        *)
            echo "Invalid choice. Please enter 1, 2, or 3."
            ;;
    esac
done

# --- Step 3: Install Extra Packages ---
# Now that we have disk space, install the extras
EXTRAS_FILE="/opt/claudian/extra-packages.txt"
if [ -f "$EXTRAS_FILE" ]; then
    clear
    cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║                   Package Installation                         ║
╚════════════════════════════════════════════════════════════════╝

EOF

    echo "Claudian includes additional tools for development, automation,"
    echo "and system control that need to be installed."
    echo ""
    echo "This includes: Python, Docker, xdotool, ffmpeg, ripgrep,"
    echo "htop, tmux, jq, and many more CLI tools."
    echo ""
    echo "Choose an option:"
    echo ""
    echo "  1) Install all extra packages (recommended)"
    echo "     Full Claudian experience with all tools"
    echo ""
    echo "  2) Skip for now"
    echo "     Minimal system, install packages later with:"
    echo "     sudo apt install \$(grep -v '^#' /opt/claudian/extra-packages.txt | tr '\\n' ' ')"
    echo ""

    while true; do
        read -p "Enter choice [1 or 2]: " pkg_choice
        case $pkg_choice in
            1)
                echo ""
                echo "Installing extra packages... (this may take a while)"
                echo ""

                # Read package list, skip comments and empty lines
                PACKAGES=$(grep -v '^\s*#' "$EXTRAS_FILE" | grep -v '^\s*$' | tr '\n' ' ')

                sudo apt-get update
                if sudo apt-get install -y $PACKAGES; then
                    echo ""
                    echo "✓ All extra packages installed successfully!"

                    # Remove the extras file since they're installed
                    sudo rm -f "$EXTRAS_FILE"
                else
                    echo ""
                    echo "⚠ Some packages may have failed to install."
                    echo "  You can retry later with:"
                    echo "  sudo apt install \$(grep -v '^#' $EXTRAS_FILE | tr '\\n' ' ')"
                fi
                echo ""
                sleep 2
                break
                ;;
            2)
                echo ""
                echo "Skipping package installation."
                echo "Install later: sudo apt install \$(grep -v '^#' $EXTRAS_FILE | tr '\\n' ' ')"
                echo ""
                sleep 2
                break
                ;;
            *)
                echo "Invalid choice. Please enter 1 or 2."
                ;;
        esac
    done
fi

# --- Step 4: Sudo Configuration ---
clear
cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║                   Security Configuration                       ║
╚════════════════════════════════════════════════════════════════╝

EOF

echo "Configure sudo access for the claude user."
echo ""
echo "Choose your preference:"
echo ""
echo "  1) Passwordless sudo (recommended for automation)"
echo "     Claude can run system commands without entering a password"
echo ""
echo "  2) Require password for sudo"
echo "     You'll need to set a password and enter it when Claude needs sudo"
echo ""

while true; do
    read -p "Enter choice [1 or 2]: " sudo_choice
    case $sudo_choice in
        1)
            # Passwordless sudo - ensure sudoers file exists
            echo ""
            echo "Configuring passwordless sudo..."

            if [ ! -f /etc/sudoers.d/claude ]; then
                echo "claude ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/claude > /dev/null
                sudo chmod 0440 /etc/sudoers.d/claude
            fi

            echo "✓ Passwordless sudo enabled"
            echo ""
            sleep 1
            break
            ;;
        2)
            # Password-required sudo
            echo ""
            echo "Setting up password for claude user..."

            # Remove passwordless sudoers file if it exists
            sudo rm -f /etc/sudoers.d/claude

            # Set password for claude user
            echo "Please enter a password for the claude user:"
            sudo passwd claude

            echo ""
            echo "✓ Password configured. You'll need to enter this when Claude uses sudo."
            echo ""
            sleep 1
            break
            ;;
        *)
            echo "Invalid choice. Please enter 1 or 2."
            ;;
    esac
done

# --- Step 5: Authentication Setup ---
clear
cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║                   Authentication Setup                         ║
╚════════════════════════════════════════════════════════════════╝

EOF

echo "Finally, let's authenticate with Anthropic."
echo ""
echo "Choose your authentication method:"
echo ""
echo "  1) Sign in with browser (recommended)"
echo "     Uses 'claude auth login' to authenticate via web browser"
echo ""
echo "  2) Enter API key manually"
echo "     Use an API key from console.anthropic.com"
echo ""

# Read choice
while true; do
    read -p "Enter choice [1 or 2]: " choice
    case $choice in
        1)
            # Use claude auth login
            echo ""
            echo "Launching authentication flow..."
            echo "Follow the prompts to sign in through your browser."
            echo ""

            # Run claude auth login
            if claude auth login; then
                echo ""
                echo "✓ Authentication successful!"
                echo ""

                # Mark onboarding as complete
                touch "$ONBOARDING_COMPLETE_FLAG"

                echo "Press Enter to continue..."
                read
                exit 0
            else
                echo ""
                echo "✗ Authentication failed. Please try again."
                echo ""
                read -p "Press Enter to retry..."
                clear
                exec "$0"  # Restart onboarding
            fi
            ;;
        2)
            # Manual API key entry
            echo ""
            echo "Enter your Anthropic API key (starts with 'sk-ant-'):"
            echo "(You can find this at https://console.anthropic.com/settings/keys)"
            echo ""
            read -p "API Key: " api_key

            # Basic validation
            if [[ ! "$api_key" =~ ^sk-ant- ]]; then
                echo ""
                echo "✗ Invalid API key format. Keys should start with 'sk-ant-'"
                echo ""
                read -p "Press Enter to try again..."
                clear
                exec "$0"  # Restart onboarding
            fi

            # Save to environment file
            echo ""
            echo "Saving API key to $ENV_FILE..."

            # Read existing environment file
            if [ -f "$ENV_FILE" ]; then
                # Remove any existing ANTHROPIC_API_KEY line
                grep -v "^ANTHROPIC_API_KEY=" "$ENV_FILE" > "$ENV_FILE.tmp" || true
                mv "$ENV_FILE.tmp" "$ENV_FILE"
            fi

            # Add the API key
            echo "ANTHROPIC_API_KEY=$api_key" >> "$ENV_FILE"

            # Export for current session
            export ANTHROPIC_API_KEY="$api_key"

            echo "✓ API key saved successfully!"
            echo ""

            # Mark onboarding as complete
            touch "$ONBOARDING_COMPLETE_FLAG"

            echo "Press Enter to continue..."
            read
            exit 0
            ;;
        *)
            echo "Invalid choice. Please enter 1 or 2."
            ;;
    esac
done
