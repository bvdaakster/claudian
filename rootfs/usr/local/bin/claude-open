#!/bin/bash
# Claude calls this to open a new terminal or app in i3
# Usage: claude-open terminal | claude-open browser <url>

ACTION="$1"
TARGET="$2"

# Chromium flags for consistent DPI and behavior
CHROMIUM_FLAGS="--force-device-scale-factor=2 --no-first-run --disable-sync"

case "$ACTION" in
  terminal)
    i3-msg "split h; exec kitty"
    ;;
  browser)
    # If chromium is already running, open URL in existing instance
    if pgrep -x chromium >/dev/null 2>&1; then
      if [ -n "$TARGET" ]; then
        chromium "$TARGET" &
      fi
    else
      i3-msg "split h; exec chromium $CHROMIUM_FLAGS \"${TARGET:-about:blank}\""
    fi
    ;;
  workspace)
    i3-msg "workspace ${TARGET:-2}"
    ;;
  *)
    echo "Usage: claude-open terminal|browser|workspace [target]"
    exit 1
    ;;
esac
